<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mark PC</title>

<style>
:root{
--main:#6c3bff;
--bg:#0b0d12;
--card:#12151c;
--text:#fff;
--sidebar:#07090d;
--btn:#25D366;
}

body{
margin:0;
font-family:Arial;
background: linear-gradient(135deg, #0b0d12, #1a1d24, #0b0d12);
color:var(--text);
display:flex;
}

/* SIDEBAR */
.sidebar{
width:70px;
background:var(--sidebar);
height:100vh;
position:fixed;
transition:.3s;
overflow:hidden;
}
.sidebar:hover{width:230px;}

.menu-item{
display:flex;
align-items:center;
padding:12px;
margin:8px;
background:#15181f;
border-radius:8px;
cursor:pointer;
}
.menu-item span{opacity:0;margin-left:10px;}
.sidebar:hover span{opacity:1}

/* MAIN */
.main{margin-left:70px;width:100%;transition:.3s;}
.sidebar:hover ~ .main{margin-left:230px}

/* HERO */
.hero{
background:url('banner.jpg') center/cover no-repeat;
height:300px;
display:flex;
align-items:center;
justify-content:center;
flex-direction:column;
text-align:center;
}

.hero h1{font-size:32px;margin:10px 0}
.hero p{opacity:.8}

.btnZap{
background:var(--btn);
padding:14px;
border-radius:10px;
color:#fff;
text-decoration:none;
display:inline-block;
margin-top:15px;
width:80%;
max-width:400px;
text-align:center;
}

.section{padding:40px 20px;text-align:center}

.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:20px;
margin-top:20px;
}

.card{
background:var(--card);
padding:20px;
border-radius:12px;
transition:.3s;
}
.card:hover{transform:scale(1.05)}

.price{color:#00ff88;font-weight:bold}

.features{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
gap:20px;
margin-top:30px;
}

.feature{
background:var(--card);
padding:20px;
border-radius:12px;
}

.hidden{display:none}
</style>
</head>

<body>

<div class="sidebar">
<div class="menu-item" onclick="openPage('home')">🏠 <span>Home</span></div>
<div class="menu-item" onclick="openPage('services')">🛠️ <span>Serviços</span></div>
<div class="menu-item" onclick="openPage('products')">🛒 <span>Produtos</span></div>

<!-- ✅ ADMIN CORRETO -->
<div class="menu-item" onclick="window.location.href='login.html'">🔒 <span>Admin</span></div>
</div>

<div class="main">

<!-- HOME (INTACTA) -->
<div id="home">
<div class="hero">
<img src="logo.png" width="90">
<h1>Computador lento?</h1>
<p>Deixamos seu PC como novo 🚀</p>
<a class="btnZap" target="_blank" href="https://wa.me/5534999046747?text=Olá quero atendimento">Falar no WhatsApp</a>
</div>

<div class="section">
<h2>🛠️ Serviços</h2>
<div class="grid">
<div class="card">
<h3>Formatação</h3>
<p>PC rápido e limpo</p>
<div class="price">R$ 80</div>
</div>

<div class="card">
<h3>Limpeza</h3>
<p>Evita travamentos</p>
<div class="price">R$ 50</div>
</div>

<div class="card">
<h3>Upgrade SSD</h3>
<p>Até 10x mais rápido</p>
<div class="price">Consultar</div>
</div>
</div>
</div>

<div class="section">
<h2>🔥 Por que escolher a MarkPC?</h2>
<div class="features">
<div class="feature">⚡ Atendimento rápido</div>
<div class="feature">💻 Especialista</div>
<div class="feature">🛡️ Segurança</div>
<div class="feature">💬 WhatsApp</div>
</div>
</div>

<div class="section">
<h2>Seu PC travando?</h2>
<p>Chama agora que resolvemos</p>
<a class="btnZap" target="_blank" href="https://wa.me/5534999046747?text=Olá quero atendimento">Chamar no WhatsApp</a>
</div>
</div>

<!-- SERVIÇOS -->
<div id="services" class="section hidden">
<h2>Serviços</h2>
<div id="serviceList" class="grid"></div>
</div>

<!-- PRODUTOS -->
<div id="products" class="section hidden">
<h2>Produtos</h2>
<div id="productList" class="grid"></div>
</div>

</div>

<script>
function openPage(p){
['home','services','products'].forEach(id=>{
document.getElementById(id).classList.add('hidden')
})
document.getElementById(p).classList.remove('hidden')
}
</script>

</body>
</html>